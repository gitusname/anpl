{
  "name": "@anpl/compiler",
  "version": "0.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --tsconfig ../../tsconfig.base.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anpl/compiler-js": "workspace:*",
    "@anpl/core": "workspace:*",
    "@anpl/formatter": "workspace:*",
    "@anpl/hir": "workspace:*",
    "@anpl/interpreter": "workspace:*",
    "@anpl/ir": "workspace:*",
    "@anpl/lexer": "workspace:*",
    "@anpl/mir": "workspace:*",
    "@anpl/optimizer": "workspace:*",
    "@anpl/parser": "workspace:*",
    "@anpl/project": "workspace:*",
    "@anpl/runtime": "workspace:*",
    "@anpl/semantic": "workspace:*",
    "@anpl/source": "workspace:*",
    "@anpl/symbols": "workspace:*",
    "@anpl/types": "workspace:*"
  }
}
