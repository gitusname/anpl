{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "../..",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "../ast/src/**/*.ts",
    "../compiler-js/src/**/*.ts",
    "../core/src/**/*.ts",
    "../formatter/src/**/*.ts",
    "../hir/src/**/*.ts",
    "../interpreter/src/**/*.ts",
    "../ir/src/**/*.ts",
    "../lexer/src/**/*.ts",
    "../mir/src/**/*.ts",
    "../optimizer/src/**/*.ts",
    "../parser/src/**/*.ts",
    "../syntax/src/**/*.ts",
    "../project/src/**/*.ts",
    "../runtime/src/**/*.ts",
    "../semantic/src/**/*.ts",
    "../source/src/**/*.ts",
    "../symbols/src/**/*.ts",
    "../types/src/**/*.ts"
  ],
  "exclude": ["**/*.test.ts", "../**/*.test.ts"]
}
