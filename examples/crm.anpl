module crm

type Customer {
  id: uuid
  name: text
  status: enum[active, archived]
  age?: int
}

fn createCustomer(name: text) -> Customer {
  return Customer {
    id: uuid()
    name: name
    status: active
  }
}

fn main() -> int {
  let customer = createCustomer("Ada")
  return len(customer.status)
}
