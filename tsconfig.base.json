{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@anpl/ast": ["packages/ast/src/index.ts"],
      "@anpl/benchmark": ["packages/benchmark/src/index.ts"],
      "@anpl/compiler": ["packages/compiler/src/index.ts"],
      "@anpl/compiler-js": ["packages/compiler-js/src/index.ts"],
      "@anpl/formatter": ["packages/formatter/src/index.ts"],
      "@anpl/hir": ["packages/hir/src/index.ts"],
      "@anpl/lexer": ["packages/lexer/src/index.ts"],
      "@anpl/core": ["packages/core/src/index.ts"],
      "@anpl/diagnostics": ["packages/diagnostics/src/index.ts"],
      "@anpl/interpreter": ["packages/interpreter/src/index.ts"],
      "@anpl/ir": ["packages/ir/src/index.ts"],
      "@anpl/lsp": ["packages/lsp/src/index.ts"],
      "@anpl/mir": ["packages/mir/src/index.ts"],
      "@anpl/optimizer": ["packages/optimizer/src/index.ts"],
      "@anpl/project": ["packages/project/src/index.ts"],
      "@anpl/runtime": ["packages/runtime/src/index.ts"],
      "@anpl/source": ["packages/source/src/index.ts"],
      "@anpl/stdlib": ["packages/stdlib/src/index.ts"],
      "@anpl/symbols": ["packages/symbols/src/index.ts"],
      "@anpl/syntax": ["packages/syntax/src/index.ts"],
      "@anpl/semantic": ["packages/semantic/src/index.ts"],
      "@anpl/parser": ["packages/parser/src/index.ts"],
      "@anpl/testkit": ["packages/testkit/src/index.ts"],
      "@anpl/types": ["packages/types/src/index.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["node"]
  }
}
